{
  "name": "@builtbyecho/reverbin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Communication infrastructure for autonomous agents: real inboxes, signed webhooks, threaded conversations, and delivery logs.",
  "main": "./dist/src/client.js",
  "types": "./dist/src/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "worker:webhooks": "node dist/src/webhook-worker.js",
    "migrate": "tsx src/migrate.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "check": "npm run build && npm test",
    "build:frontend": "npm run build && node scripts/build-frontend.mjs",
    "setup:stripe-products": "node scripts/setup-stripe-products.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "bullmq": "^5.65.1",
    "fastify": "^5.6.2",
    "ioredis": "^5.8.2",
    "nanoid": "^5.1.6",
    "pg": "^8.16.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
