# Reverbin local/dev environment
PORT=8797
HOST=127.0.0.1
DATABASE_URL=postgresql://agent_email_layer:change-me@127.0.0.1:5432/agent_email_layer
REDIS_URL=redis://127.0.0.1:6379
# sync = direct POST in API process; queue = enqueue to Redis/BullMQ and run npm run worker:webhooks after npm run build
WEBHOOK_DELIVERY_MODE=sync
PUBLIC_BASE_URL=http://127.0.0.1:8797
ECHO_EMAIL_API_KEY=change-me
# Optional dedicated app-level dashboard token. Falls back to ECHO_EMAIL_API_KEY when unset.
DASHBOARD_TOKEN=
ECHO_EMAIL_WEBHOOK_SECRET=change-me

# outbound provider; mock is safest for local dev, Resend is the live provider after DNS/domain verification
EMAIL_PROVIDER=mock
DEFAULT_FROM_EMAIL=agent@agents.builtbyecho.xyz

# Resend live mode
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# Agent webhook subscriptions are created through POST /v1/webhooks.
# Per-endpoint signing secrets are stored in Postgres and are never returned by list routes.
