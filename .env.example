# Agent Email Layer local/dev environment
PORT=8797
HOST=127.0.0.1
DATABASE_URL=postgresql://agent_email_layer:change-me@127.0.0.1:5432/agent_email_layer
REDIS_URL=redis://127.0.0.1:6379
PUBLIC_BASE_URL=http://127.0.0.1:8797
ECHO_EMAIL_API_KEY=change-me
ECHO_EMAIL_WEBHOOK_SECRET=change-me

# outbound provider; mock is safest for first deploy
EMAIL_PROVIDER=mock
DEFAULT_FROM_EMAIL=agent@agents.builtbyecho.xyz

# Resend when ready
RESEND_API_KEY=
RESEND_FROM_EMAIL=
